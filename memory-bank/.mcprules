# СТРАТЕГИЯ: Token-Efficiency & Lazy Loading
# СТАТУС: Всегда начинай ответ с [MODE: <режим>] [MEMORY BANK: ACTIVE/INACTIVE]

global_rules:
  - "Префикс: КАЖДЫЙ ответ начинай с [MODE: <режим>]"
  - "Anti-Loop Protocol: После 5 неудачных итераций — STOP и отчет."
  - "Memory Bank: Используй только 4 файла (active-context, product-context, system-patterns, progress)."
  - "Экономия: Не читай файлы целиком, используй grep/search."
  - "Правки: Используй apply_diff (не переписывай файлы целиком)."

common_rules:
  - "Запись решений: ЛЮБОЕ изменение архитектуры, выбор новой библиотеки или смена паттерна ДОЛЖНЫ быть зафиксированы в decision-log.md."
  - "Используй apply_diff для правок (не переписывай файлы целиком)."
  - "Читай только active-context.md. Остальное — по необходимости."
  - "UMB (Update Memory Bank): Переключайся в umb:true только для записи в *.md."

modes:
  architect:
    focus: "Структура и дизайн. Создание/правка *.md файлов памяти."
    trigger: "архитектурные изменения, новый стек, инициализация проекта."
  code:
    focus: "Реализация логики. Полный доступ к src. Чистый код DRY/KISS."
    trigger: "написание функций, фикс багов, рефакторинг."
  debug:
    focus: "Диагностика. Гипотеза -> Проверка (logs) -> Подтверждение."
    trigger: "анализ ошибок, поиск первопричины. Код менять запрещено."
  test:
    focus: "Качество. Запуск execute_command. Фиксация % покрытия."
    trigger: "проверка функционала, создание тест-кейсов."
  ask:
    focus: "Справка. Ответы на вопросы без правок файлов. Только чтение."
    trigger: "разъяснение кода, поиск в документации."

# ПРАВИЛА ПРОЦЕССОВ (Автоматизация)
processes:
  umb:
    trigger: "(?i)\b(umb|update|archive)\b"
    instructions:
      - "1. switch_mode(umb=true)."
      - "2. Очистка: Удали из всех .md файлов пустые заглушки [Context], [Date], [Decision]."
      - "3. Анализ: Если в progress.md (Decision Log) есть пустые пункты — заполни на основе кода."
      - "4. Архивация: Перенеси [X] задачи из progress.md в раздел ## Archive."
      - "5. Сброс: Очисти active-context.md, оставив только резюме последней правки."
      - "6. Лаконичность: Только буллиты, без вводных фраз."
      - "7. switch_mode(umb=false)."

  anti_loop:
    max_attempts: 5
    instructions:
      - "Если задача не решена за 5 итераций:"
      - "1. ОСТАНОВИСЬ. Выведи 'DIAGNOSTIC REPORT'."
      - "2. СТРУКТУРА: Проблема, 5 Попыток (с логами), Гипотеза, Запрос к пользователю."
      - "3. ПАУЗА: Жди ответа пользователя."
